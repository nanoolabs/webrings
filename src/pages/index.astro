---
import "@/styles/index.css"
import { getCollection } from "astro:content"
import { version } from "../../package.json"

const allSites = await getCollection("rings")
const sites = allSites.filter((site) => site.id !== "rings.json")
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>NANOO // NETWORK_REGISTRY</title>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="brand">NANOO LABS // REGISTRY</div>
        <div class="status-tag">SYSTEM OPERATIONAL</div>
      </header>

      <main>
        <h1>Nanoo network registry.</h1>
        <p class="registry-desc">
          Official index of active nodes within the Nanoo federation. Optimize
          for low-latency navigation and decentralized discovery.
        </p>

        <table class="node-table">
          <thead>
            <tr>
              <th>Node_ID</th>
              <th>Federation_Ring</th>
              <th style="text-align: right">Access</th>
            </tr>
          </thead>
          <tbody>
            {
              sites.map((site) => {
                const [ringName, siteId] = site.id.split("/")
                const cleanId = siteId.replace(".json", "")
                return (
                  <tr>
                    <td>
                      <span class="node-id">{cleanId}</span>
                    </td>
                    <td>
                      <span class="node-ring">{ringName}</span>
                    </td>
                    <td style="text-align: right">
                      <a
                        href={`/next?site=${cleanId}&ring=${ringName}`}
                        class="node-link"
                      >
                        [ Track_Node ]
                      </a>
                    </td>
                  </tr>
                )
              })
            }
          </tbody>
        </table>
      </main>

      <footer>
        <div>&copy; 2026 NANOO LABS</div>
        <div>V{version} // REGISTRY_NODE</div>
      </footer>
    </div>
  </body>
</html>
